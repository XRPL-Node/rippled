    {sfVaultID, soeREQUIRED},
    {sfLoanBrokerID, soeOPTIONAL},
    {sfData, soeOPTIONAL},
    {sfManagementFeeRate, soeOPTIONAL},
    {sfDebtMaximum, soeOPTIONAL},
    {sfCoverRateMinimum, soeOPTIONAL},
    {sfCoverRateLiquidation, soeOPTIONAL},
}))

