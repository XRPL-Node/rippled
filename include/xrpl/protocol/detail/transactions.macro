    Emittance::emitable,
    ({
    {sfLoanBrokerID, soeREQUIRED},
    {sfData, soeOPTIONAL},
    {sfCounterparty, soeOPTIONAL},
    {sfCounterpartySignature, soeOPTIONAL},
    {sfLoanOriginationFee, soeOPTIONAL},
    {sfLoanServiceFee, soeOPTIONAL},
    {sfLatePaymentFee, soeOPTIONAL},
